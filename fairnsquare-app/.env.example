# Local Quarkus configuration — copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# CORS origins allowed by the backend (comma-separated).
# Defaults to localhost only when this variable is not set.
# Add your local tunnel URL here when using tools like ngrok or localtunnel.
# FAIRNSQUARE_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://your-tunnel.ngrok-free.dev