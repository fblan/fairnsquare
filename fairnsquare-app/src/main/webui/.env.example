# Local Vite dev server configuration — copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Hosts allowed by the Vite dev server (comma-separated).
# When not set, Vite uses its default host validation.
# Add your local tunnel hostname(s) here when using tools like ngrok or localtunnel.
# VITE_ALLOWED_HOSTS=my.sample.url.ngrok.com